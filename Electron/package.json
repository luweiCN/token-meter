{
  "name": "token-meter-electron",
  "private": true,
  "type": "module",
  "main": "dist-main/main/main.js",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "electron": "electron .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build": "vite build && vite build --mode preload && tsc --ignoreConfig --outDir dist-main --rootDir src --module NodeNext --moduleResolution NodeNext --target ES2022 --skipLibCheck --types node --strict --esModuleInterop --jsx react-jsx src/main/main.ts src/main/ipc.ts",
    "rebuild:native": "electron-rebuild"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@vitejs/plugin-react": "latest",
    "better-sqlite3": "latest",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "electron": "latest",
    "lucide-react": "^1.24.0",
    "radix-ui": "^1.6.2",
    "react": "latest",
    "react-day-picker": "^10.0.1",
    "react-dom": "latest",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "uplot": "^1.6.32"
  },
  "devDependencies": {
    "@electron/rebuild": "latest",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "jsdom": "^29.1.1",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "latest"
  }
}
